{
  "name": "folio",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @folio/desktop dev",
    "build": "pnpm --filter @folio/desktop build",
    "pack:dir": "pnpm --filter @folio/desktop pack:dir",
    "dist": "pnpm --filter @folio/desktop dist",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
